#!/bin/bash -eu

# Config Vars
BACKUP_DIR="{{ tas_single_node_data_protection.backup.directory }}" # Main backup directory
CONFIG_DIR="/etc/rhtas"
VOLUMES_DIR="/var/lib/containers/storage/volumes"
PASSPHRASE="{{ tas_single_node_data_protection.backup.passphrase }}"
LOG_FILE="/var/log/tas_backup.log"
BACKUP_MODE_ACTIVE_FILE="/tmp/backup_mode_active"

# logging Messages
log() {
  echo "$(date -u +'%Y-%m-%dT%H:%M:%SZ') - $1" >> "$LOG_FILE"
}

# Error Handling
error_exit() {
  log "ERROR: $1"
  exit 1
}

# Create backup_mode_active file
touch "$BACKUP_MODE_ACTIVE_FILE"

# Create Backup Directory
TIMESTAMP=$(date -u +BACKUP-%Y-%m-%d-%H-%M-UTC)
BACKUP_TIMESTAMP_DIR="$BACKUP_DIR/$TIMESTAMP"

mkdir -p "$BACKUP_TIMESTAMP_DIR" || error_exit "Failed to create backup directory: $BACKUP_TIMESTAMP_DIR"
log "Created backup directory: $BACKUP_TIMESTAMP_DIR"

# Stop Podman Containers
podman stop $(podman ps -aq) 2>> "$LOG_FILE" || log "Warning: Failed to stop some podman containers."
log "Stopped Podman containers."

# Copy Config Files
cp -r "$CONFIG_DIR" "$BACKUP_TIMESTAMP_DIR/" || error_exit "Failed to copy configuration files."
log "Copied configuration files."

# Copy Podman Volumes
cp -r "$VOLUMES_DIR" "$BACKUP_TIMESTAMP_DIR/" || error_exit "Failed to copy Podman volumes."
log "Copied Podman volumes."

# Start Podman Containers
podman start $(podman ps -aq --filter "status=exited") 2>> "$LOG_FILE" || log "Warning: Failed to start some podman containers."
log "Started Podman containers."

# Create Compressed Backup Tarball
cd "$(dirname "$BACKUP_TIMESTAMP_DIR")" && tar -czvf "$(basename "$BACKUP_TIMESTAMP_DIR").tar.gz" "$(basename "$BACKUP_TIMESTAMP_DIR")" 2>> "$LOG_FILE" || error_exit "Failed to create compressed tarball."
log "Created compressed tarball: $BACKUP_TIMESTAMP_DIR.tar.gz"

# Delete Uncompressed Backup Directory
rm -rf "$BACKUP_TIMESTAMP_DIR" || log "Warning: Failed to delete uncompressed backup directory."
log "Deleted uncompressed backup directory."

# Encrypt Backup Tarball
openssl enc -aes-256-cbc -salt -pbkdf2 -iter 600000 -in "$BACKUP_TIMESTAMP_DIR.tar.gz" -out "$BACKUP_TIMESTAMP_DIR.tar.gz.enc" -pass pass:"$PASSPHRASE" 2>> "$LOG_FILE" || error_exit "Failed to encrypt tarball."
log "Encrypted tarball: $BACKUP_TIMESTAMP_DIR.tar.gz.enc"

# Delete Unencrypted Backup Tarball
rm -f "$BACKUP_TIMESTAMP_DIR.tar.gz" || log "Warning: Failed to delete unencrypted tarball."
log "Deleted unencrypted tarball."

# Delete backup_mode_active File
rm -f "$BACKUP_MODE_ACTIVE_FILE"

log "Backup completed successfully."
exit 0
